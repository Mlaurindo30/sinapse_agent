diff --git a/graphify/sqlite_export.py b/graphify/sqlite_export.py
new file mode 100644
index 0000000..5cbf65e
--- /dev/null
+++ b/graphify/sqlite_export.py
@@ -0,0 +1,127 @@
+import sqlite3
+import json
+import os
+import hashlib
+import sys
+from pathlib import Path
+import networkx as nx
+
+# Importa o core do UMC
+SINAPSE_HOME = os.environ.get("SINAPSE_HOME", str(Path(__file__).resolve().parent.parent.parent.parent))
+sys.path.append(SINAPSE_HOME)
+try:
+    from core.database import serialize_f32, get_embedder
+    import sqlite_vec
+except ImportError:
+    serialize_f32 = get_embedder = sqlite_vec = None
+
+def to_sqlite(G: nx.Graph, communities: dict[int, list[str]], db_path: str):
+    """Exporta o grafo NetworkX para o banco de dados SQLite UMC."""
+    print(f"[umc] Conectando ao banco em: {os.path.abspath(db_path)}")
+    if not serialize_f32 or not get_embedder or not sqlite_vec:
+        print("[umc] Erro: core.database não encontrado.")
+        return
+
+    conn = sqlite3.connect(db_path, timeout=30)
+    conn.row_factory = sqlite3.Row
+    conn.execute("PRAGMA foreign_keys=ON")
+    conn.execute("PRAGMA busy_timeout=10000")
+    conn.enable_load_extension(True)
+    try:
+        sqlite_vec.load(conn)
+    finally:
+        conn.enable_load_extension(False)
+    cursor = conn.cursor()
+
+    # Mapeamento de comunidades
+    node_community = {}
+    for comm_id, nodes in communities.items():
+        for node_id in nodes:
+            node_community[node_id] = comm_id
+
+    embedder = get_embedder()
+
+    # Sincronizar Neurônios (Nodes)
+    print(f"[umc] Sincronizando {G.number_of_nodes()} neurônios...")
+    for node_id, data in G.nodes(data=True):
+        label = data.get("label", node_id)
+        node_type = data.get("file_type", "unknown")
+        source_file = data.get("source_file", "")
+        content = data.get("content", "")
+
+        # Se o conteúdo estiver vazio mas houver source_file, tenta ler do disco
+        if not content and source_file:
+            try:
+                candidates = (
+                    os.path.join(SINAPSE_HOME, source_file),
+                    os.path.join(SINAPSE_HOME, "cerebro", source_file),
+                )
+                for full_path in candidates:
+                    if os.path.isfile(full_path):
+                        with open(full_path, "r", encoding="utf-8") as f:
+                            content = f.read()
+                        break
+            except Exception:
+                pass
+
+        comm = node_community.get(node_id, 0)
+
+        # Calcula hash do conteúdo
+        embedding_text = content or label
+        content_hash = hashlib.sha256(embedding_text.encode()).hexdigest()
+
+        metadata = json.dumps({k: v for k, v in data.items() if k not in ["label", "file_type", "source_file", "content"]})
+
+        previous = cursor.execute(
+            "SELECT hash FROM neurons WHERE id = ?", (node_id,)
+        ).fetchone()
+        content_changed = previous is None or previous["hash"] != content_hash
+
+        cursor.execute("""
+            INSERT INTO neurons (id, label, type, source_file, content, hash, community, metadata, updated_at)
+            VALUES (?, ?, ?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP)
+            ON CONFLICT(id) DO UPDATE SET
+                label=excluded.label,
+                type=excluded.type,
+                source_file=excluded.source_file,
+                content=excluded.content,
+                hash=excluded.hash,
+                community=excluded.community,
+                metadata=excluded.metadata,
+                indexed_at=CASE
+                    WHEN neurons.hash IS NOT excluded.hash THEN NULL
+                    ELSE neurons.indexed_at
+                END,
+                updated_at=CURRENT_TIMESTAMP
+        """, (node_id, label, node_type, source_file, content, content_hash, comm, metadata))
+
+        # Gera e salva embedding se houver conteúdo e embedder disponível
+        if embedding_text and embedder:
+            try:
+                cursor.execute(
+                    "SELECT neuron_id FROM search_vec WHERE neuron_id = ?", (node_id,)
+                )
+                if content_changed or not cursor.fetchone():
+                    vec = list(embedder.embed(embedding_text[:5000]))[0].tolist()
+                    serialized = serialize_f32(vec)
+                    cursor.execute("INSERT OR REPLACE INTO search_vec (neuron_id, embedding) VALUES (?, ?)", (node_id, serialized))
+            except Exception as e:
+                print(f"[umc] Warning: embedding failed for {node_id}: {e}", file=sys.stderr)
+
+    # Sincronizar Sinapses (Edges)
+    print(f"[umc] Sincronizando {G.number_of_edges()} sinapses...")
+    cursor.execute("DELETE FROM synapses")
+
+    for u, v, data in G.edges(data=True):
+        relation = data.get("relation", "connected")
+        weight = data.get("weight", 1.0)
+        metadata = json.dumps({k: v for k, v in data.items() if k not in ["relation", "weight"]})
+
+        cursor.execute("""
+            INSERT INTO synapses (source_id, target_id, relation, weight, metadata)
+            VALUES (?, ?, ?, ?, ?)
+        """, (u, v, relation, weight, metadata))
+
+    conn.commit()
+    conn.close()
+    print("[umc] Sincronização estrutural e vetorial concluída.")
