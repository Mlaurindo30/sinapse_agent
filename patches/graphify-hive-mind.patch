diff --git a/tests/test_watch.py b/tests/test_watch.py
index f5b332f..ba3ed50 100644
--- a/tests/test_watch.py
+++ b/tests/test_watch.py
@@ -4,0 +5 @@ import time
+import json
@@ -212,0 +214,26 @@ def test_rebuild_code_skips_cluster_when_topology_unchanged(tmp_path, monkeypatc
+def test_incremental_rebuild_removes_deleted_extractor_nodes(tmp_path):
+    from graphify.watch import _rebuild_code
+
+    src = tmp_path / "deleted_later.py"
+    src.write_text("def removed_symbol():\n    return 1\n", encoding="utf-8")
+    assert _rebuild_code(tmp_path, changed_paths=[src], force=True)
+
+    graph_path = tmp_path / "graphify-out" / "graph.json"
+    graph = json.loads(graph_path.read_text(encoding="utf-8"))
+    graph["nodes"].append({
+        "id": "semantic-rationale",
+        "label": "Preserved rationale",
+        "file_type": "rationale",
+        "source_file": "semantic-rationale",
+    })
+    graph_path.write_text(json.dumps(graph), encoding="utf-8")
+
+    src.unlink()
+    (tmp_path / "remaining.py").write_text("def kept_symbol():\n    return 2\n", encoding="utf-8")
+    assert _rebuild_code(tmp_path, changed_paths=[src], force=True)
+
+    rebuilt = json.loads(graph_path.read_text(encoding="utf-8"))
+    assert not any(n.get("source_file") == "deleted_later.py" for n in rebuilt["nodes"])
+    assert any(n.get("id") == "semantic-rationale" for n in rebuilt["nodes"])
+
+
