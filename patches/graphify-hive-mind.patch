+# Extensions that trigger Hive-Mind media/document capture pipelines
+_HIVE_IMAGE_EXTENSIONS = {".png", ".jpg", ".jpeg", ".gif"}
+_HIVE_DOC_EXTENSIONS = {".pdf", ".docx"}
+
+# Debounce tracking: {absolute_path_str: last_processed_monotonic_time}
+_hive_capture_debounce: dict[str, float] = {}
+_HIVE_DEBOUNCE_SECONDS = 30.0
+
+
+def _trigger_document_ingest(file_path: Path) -> None:
+    """Call document_ingest.py --file <path> for a single PDF or DOCX file.
+
+    Uses subprocess.run with check=False so a capture failure never crashes
+    the watcher. Applies a 30-second per-file debounce.
+    """
+    abs_path = str(file_path.resolve())
+    now = time.monotonic()
+    if now - _hive_capture_debounce.get(abs_path, 0.0) < _HIVE_DEBOUNCE_SECONDS:
+        return
+    _hive_capture_debounce[abs_path] = now
+
+    script = Path(__file__).resolve().parent.parent.parent / "scripts" / "document_ingest.py"
+    if not script.exists():
+        print(f"[graphify watch] document_ingest.py not found at {script}", file=sys.stderr)
+        return
+
+    print(f"[graphify watch] [hive] Ingesting document: {file_path.name}")
+    result = subprocess.run(
+        [sys.executable, str(script), "--file", abs_path],
+        check=False,
+        capture_output=True,
+        text=True,
+        env={**os.environ, "SINAPSE_HOME": os.environ.get("SINAPSE_HOME", str(script.parent.parent))},
+    )
+    if result.returncode != 0:
+        print(
+            f"[graphify watch] [hive] document_ingest failed for {file_path.name}: "
+            f"{result.stderr.strip()}",
+            file=sys.stderr,
+        )
+
