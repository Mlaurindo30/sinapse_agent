# Sinapse Agent — Environment Variables
# Copie este arquivo para .env e configure as variáveis.
# .env NÃO é commitado (está no .gitignore).

# ── Gemini API (Google) ─────────────────────────────────────────────────
# Usado pelo Graphify para extração semântica do knowledge graph.
# Sem esta key, o Graphify usa AST-only (tree-sitter) ou Ollama local.
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── Ollama (opcional) ───────────────────────────────────────────────────
# Modelos recomendados para extração semântica local:
#   ollama pull qwen2.5-coder:3b    # Extração semântica (1.9GB)
#   ollama pull snowflake-arctic-embed2               # Embeddings (1.2GB)
#   ollama pull nomic-embed-text     # Embeddings leve (0.3GB)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:3b

# ── LLM por papel (role-based) ───────────────────────────────────────────────
# Papéis: DREAMER (base), GRAPHIFY, VISION, SYNTHESIS.
# Herança: papel sem PROVIDER+MODEL próprios herda os do Dreamer (e também o
# fallback do Dreamer). Papel com primário próprio usa apenas o próprio fallback.
# Chaves de API ficam só nas vars do provedor (GOOGLE_API_KEY etc.) — nunca por papel.
HIVE_DREAMER_PROVIDER=
HIVE_DREAMER_MODEL=
HIVE_DREAMER_FALLBACK_PROVIDER=
HIVE_DREAMER_FALLBACK_MODEL=
HIVE_GRAPHIFY_PROVIDER=
HIVE_GRAPHIFY_MODEL=
HIVE_GRAPHIFY_FALLBACK_PROVIDER=
HIVE_GRAPHIFY_FALLBACK_MODEL=
HIVE_VISION_PROVIDER=
HIVE_VISION_MODEL=
HIVE_VISION_FALLBACK_PROVIDER=
HIVE_VISION_FALLBACK_MODEL=
HIVE_SYNTHESIS_PROVIDER=
HIVE_SYNTHESIS_MODEL=
HIVE_SYNTHESIS_FALLBACK_PROVIDER=
HIVE_SYNTHESIS_FALLBACK_MODEL=
# Nota: o EMBEDDING padrão é local via Ollama
# (snowflake-arctic-embed2:latest, 1024d). Pode ser sobrescrito por env para
# debug/migração, mas todos os índices canônicos usam 1024 dimensões.
EMBED_BACKEND=ollama
OLLAMA_EMBED_MODEL=snowflake-arctic-embed2:latest

# ── CR-SQLite (vendor opcional — sync multi-device via CRDT) ─────────────────
# Habilita sincronização CRDT do hive_mind.db entre múltiplas instâncias.
# Opt-in: default false (zero overhead). Requer install.sh ter baixado
# o binário em integrations/crsqlite/ (etapa 13 do install.sh, ou
# INSTALL_CRSQLITE=true bash install.sh).
# Schema do hive_mind.db precisa ser CRR-compatível (PK NOT NULL DEFAULT)
# - ver scripts/setup/setup_crdt.py e core/umc_schema_crr.sql.
HIVE_CRDT_SYNC=false
HIVE_CRSQLITE_VERSION=0.16.3

# ── Langfuse / OpenTelemetry (observabilidade opt-in) ─────────────────────────
# Tracing distribuído dos scripts do Hive-Mind (Dream Cycle, capture_core,
# sinapse-mcp). Opt-in: comente (deixe vazio) para desabilitar — zero
# overhead quando nenhum key setada. Com keys setadas, exports OTLP/HTTP
# são enviados ao Langfuse ou qualquer collector OTel compatível.
# Subir Langfuse local: docker compose -f docker-compose.langfuse.yml up -d
# UI em http://localhost:3100 (criar projeto + copiar keys em Settings).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3100
