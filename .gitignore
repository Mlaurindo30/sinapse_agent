# Sinapse Agent — .gitignore

# ── Vault Obsidian ─────────────────────────────────────────────────
cerebro/.obsidian/workspace.json
cerebro/.obsidian/workspace-mobile.json
cerebro/.trash/
cerebro.backup*
# Vault: conteúdo runtime (sessões, inbox, trabalho ativo, decisões, projetos)
cerebro/cerebelo/sessoes/
cerebro/cerebro/
cerebro/cortex/frontal/decisoes/
cerebro/cortex/frontal/projetos/
cerebro/cortex/frontal/trabalho/
cerebro/cortex/insula/
cerebro/cortex/parietal/inbox/
# Vault: neurônios individuais (gerados pelo Dream Cycle)
cerebro/cortex/temporal/**/neuronio-*.md
# Vault: projetos externos ao Hive-Mind (memória de outros repositórios)
cerebro/cortex/temporal/ComfyUI/
cerebro/cortex/temporal/OpenAlice/
cerebro/cortex/temporal/Thoth/
cerebro/cortex/temporal/agent-langgraph/
cerebro/cortex/temporal/e2e-chatbot-app-next/
cerebro/cortex/temporal/michel/
cerebro/cortex/temporal/open-design/
cerebro/cortex/temporal/openclaw-crestodian-planner-NyDaMs/

# ── Graphify output (artefatos runtime — regenerados, não commitar) ──
cerebro/graphify-out/
graphify-out/

# ── Dependências ───────────────────────────────────────────────────
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# ── Binários CR-SQLite (P8) — baixados pelo install.sh, não commitar ──
integrations/crsqlite/crsqlite.so
integrations/crsqlite/crsqlite.dylib
integrations/crsqlite/crsqlite.dll

# ── Sistema ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
# Config local de máquina (systemd user units — instalar via script)
.config/

# ── Logs ───────────────────────────────────────────────────────────
*.log
logs/
cerebro/thinking/session-logs/

# ── Runtime data ───────────────────────────────────────────────────
claude-mem/data/
integrations/rtk/target/
backups/

# ── Hermes agent local ────────────────────────────────────────────
.hermes/

# ── Embedded repos ─────────────────────────────────────────────────
claude-mem/
integrations/graphify/
integrations/neural-memory/
integrations/rtk/

# ── Secrets ─────────────────────────────────────────────────────────
.env
.env.*
*.secret
config/keys/
config/component-lock-backups/
.tools/

# ── Bancos de dados locais (memória pessoal — nunca commitar) ───────
hive_mind.db
hive_mind.db-*
hive_mind.db.bak
*.db.bak
banco.db
ruvector.db

# ── Venvs auxiliares ─────────────────────────────────────────────────
.venv-sqlite-vec/
.pytest_cache/

# ── Pastas de ferramentas e agentes locais (não commitar) ────────────
.claude/
.claude-flow/
.gemini/
.kiro/
.opencode/
.swarm/
.kilo/
.mcp.json

# ── Índices neurais (artefatos runtime — regenerados automaticamente) ─
hnsw_neurons.idx
hnsw_neurons.map.json
*.neuralmemory/

# ── Outputs de sessão (gerados em runtime, não fazem parte do código) ─
council_responses.txt
*.bak

# ── Arquivos temporários e de testes do workspace ────────────────────
contrarian_prompt.md
framed_question.txt
run_council.py
